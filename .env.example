# Google Places API key (required for Phase 1 company discovery)
# Get one at: https://console.cloud.google.com/ -> Enable Places API
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Google Custom Search Engine (optional, for future use)
GOOGLE_CSE_API_KEY=your_google_cse_api_key_here
GOOGLE_CSE_ID=your_google_cse_cx_id_here
